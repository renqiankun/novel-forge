{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "electron/main/index.ts",
    "electron/main/dbInit.ts",
    "electron/main/db/dbConnect.ts",
    "electron/main/db/schema/index.ts",
    "electron/main/auto-update/**/*.ts",
    "electron/main/ipc/**/*.ts",
    "electron/main/logger/**/*.ts",
    "electron/main/mcp/**/*.ts",
    "electron/main/utils/**/*.ts",
    "electron/shared/**/*.ts",
    "electron/preload/index.ts",
    "electron/preload/modules/**/*.ts",
    "vite.config.*",
    "eslint.config.*",
    "drizzle.config.ts"
  ],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@main/*": ["./electron/main/*"]
    },
    "types": ["node"],
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
