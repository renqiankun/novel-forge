{
  "name": "novel-forge-desktop",
  "productName": "NovelForge",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist-electron/main/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "pnpm run db:generate && vue-tsc --build && cross-env NODE_ENV=production vite build && electron-builder",
    "db:generate": "cross-env NODE_ENV=development pnpm drizzle-kit generate",
    "db:push": "set ELECTRON_RUN_AS_NODE=true && cross-env NODE_ENV=development electron ./node_modules/drizzle-kit/bin.cjs push",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write renderer electron"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.13.3",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "34.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
